# LLM Worker — Remote Backend Configuration
#
# Copy this file to .env.remote_worker and fill in the values.

# Use the remote HTTP backend instead of direct MongoDB access
LLM_WORKER_BACKEND=remote

# Base URL of the rsstag API server
LLM_WORKER_API_URL=http://127.0.0.1:8000

# Bearer token for authenticating with the rsstag API
LLM_WORKER_TOKEN=your-secret-worker-token

# Path to the JSON file that describes which LLM providers this worker supports
# See remote_worker_providers.example.json for the expected format
LLM_WORKER_PROVIDER_CONFIG=/path/to/remote_worker_providers.json

# Optional: override the worker process identifier (defaults to llm-worker-<pid>)
# LLM_WORKER_ID=my-remote-worker-1

# Optional: number of concurrent worker threads (default: 1)
# LLM_WORKER_CONCURRENCY=2

# Optional: how long (seconds) a claimed task lease is held (default: 60, min: 10)
# LLM_WORKER_LEASE_SECONDS=60

# Optional: how often (seconds) the worker sends a heartbeat to keep its lease (default: 20)
# LLM_WORKER_HEARTBEAT_INTERVAL_SECONDS=20

# Optional: poll interval (seconds) when the queue is empty (default: 0.5)
# LLM_WORKER_POLL_INTERVAL=0.5

# Optional: path to a file that is touch()'d on each poll iteration for liveness probes
# LLM_WORKER_HEARTBEAT_FILE=/tmp/llm_worker_alive
